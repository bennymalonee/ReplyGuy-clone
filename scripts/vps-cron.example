# ReplyGuy VPS cron (daily 06:00 UTC)
# Replace YOUR_DOMAIN and CRON_SECRET with values from your .env.local
#
# 0 6 * * * curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://YOUR_DOMAIN/api/cron/campaign/post
# 0 6 * * * curl -fsS -H "Authorization: Bearer $CRON_SECRET" https://YOUR_DOMAIN/api/cron/campaign/comment
